{
  "name": "ROS Noetic Development Container",
  "dockerComposeFile": "../devenv/docker-compose.yaml",
  "service": "ros",
  "workspaceFolder": "/workspaces/open_mower_ros",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "ms-python.python",
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack",
        "ms-iot.vscode-ros"
      ]
    }
  },
  "remoteUser": "dev",
  "initializeCommand":
      "git submodule update --init --recursive && docker pull ghcr.io/profiluefter/open_mower_ros-devenv:latest || true",
  "forwardPorts": [
    8080
  ]
}
